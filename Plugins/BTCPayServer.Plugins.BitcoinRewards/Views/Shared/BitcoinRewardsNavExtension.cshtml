@using BTCPayServer.Abstractions.Contracts
@using BTCPayServer.Abstractions.Extensions
@using Microsoft.AspNetCore.Mvc.TagHelpers
@inject IScopeProvider ScopeProvider
@{
    var storeId = ScopeProvider.GetCurrentStoreId();
}

@if (!string.IsNullOrEmpty(storeId))
{
    <li class="nav-item">
        <a asp-controller="UIBitcoinRewards" asp-action="EditSettings" asp-route-storeId="@storeId" class="nav-link" id="Nav-BitcoinRewards">
            <svg role="img" class="icon icon-plugin" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M16 2L20 12L30 14L22 21L24 31L16 26L8 31L10 21L2 14L12 12L16 2Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <line x1="16" y1="8" x2="16" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="12" y1="14" x2="20" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="12" y1="16" x2="20" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="12" y1="18" x2="20" y2="18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="16" y1="22" x2="16" y2="24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span>Bitcoin Rewards</span>
        </a>
    </li>
    <li class="nav-item">
        <a asp-controller="UIWalletManagement" asp-action="ListWallets" asp-route-storeId="@storeId" class="nav-link" id="Nav-CustomerWallets">
            <svg role="img" class="icon icon-plugin" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="4" y="6" width="24" height="20" rx="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <line x1="4" y1="14" x2="28" y2="14" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="22" cy="20" r="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
            </svg>
            <span>Customer Wallets</span>
        </a>
    </li>
    <li class="nav-item">
        <a asp-controller="UIBitcoinRewards" asp-action="RewardsHistory" asp-route-storeId="@storeId" class="nav-link" id="Nav-RewardsHistory">
            <svg role="img" class="icon icon-plugin" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="16" cy="16" r="12" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <polyline points="16,8 16,16 22,16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            </svg>
            <span>Rewards History</span>
        </a>
    </li>
    <li class="nav-item">
        <a asp-controller="UIBitcoinRewards" asp-action="ErrorDashboard" asp-route-storeId="@storeId" class="nav-link" id="Nav-ErrorDashboard">
            <svg role="img" class="icon icon-plugin" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M16 4L2 28H30L16 4Z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
                <line x1="16" y1="13" x2="16" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="16" cy="24" r="1" fill="currentColor"/>
            </svg>
            <span>Error Dashboard</span>
        </a>
    </li>
    <li class="nav-item">
        <a asp-controller="UIBitcoinRewards" asp-action="RateLimitSettings" asp-route-storeId="@storeId" class="nav-link" id="Nav-RateLimits">
            <svg role="img" class="icon icon-plugin" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="4" y="12" width="24" height="14" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <path d="M10 12V9a6 6 0 0 1 12 0v3" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <circle cx="16" cy="20" r="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
            </svg>
            <span>Rate Limits</span>
        </a>
    </li>
    <li class="nav-item">
        <a asp-controller="UIBitcoinRewards" asp-action="CreateTestReward" asp-route-storeId="@storeId" class="nav-link" id="Nav-TestReward">
            <svg role="img" class="icon icon-plugin" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 4H20L22 10H10L12 4Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <rect x="8" y="10" width="16" height="18" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <line x1="12" y1="16" x2="20" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="12" y1="20" x2="18" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span>Test Reward</span>
        </a>
    </li>
}
