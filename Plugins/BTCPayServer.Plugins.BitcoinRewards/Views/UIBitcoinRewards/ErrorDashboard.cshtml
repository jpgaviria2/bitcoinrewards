@using BTCPayServer.Plugins.BitcoinRewards.ViewModels
@model ErrorDashboardViewModel
@{
    ViewData.SetActivePage("BitcoinRewards", "Error Dashboard", "BitcoinRewardsErrors");
    Layout = "_Layout";
}

@{ ViewData["ActiveNav"] = "Errors"; }
<partial name="_PluginNav" />
<h3>Error Dashboard</h3>

<div class="row mb-4">
    <div class="col-12">
        <div class="row">
            <div class="col-md-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title text-muted small">Total Errors</h5>
                        <p class="h2">@Model.Statistics.TotalErrors</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title text-muted small">Unresolved</h5>
                        <p class="h2 text-warning">@Model.Statistics.UnresolvedErrors</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title text-muted small">Retryable</h5>
                        <p class="h2 text-info">@Model.Statistics.RetryableErrors</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title text-muted small">Time Range</h5>
                        <p class="h2">@Model.DaysFilter days</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-3">
    <div class="col-12">
        <form method="get" class="form-inline">
            <div class="form-group mr-3">
                <label for="days" class="mr-2">Days:</label>
                <select name="days" id="days" class="form-control" onchange="this.form.submit()">
                    <option value="1" selected="@(Model.DaysFilter == 1)">Last 24 hours</option>
                    <option value="7" selected="@(Model.DaysFilter == 7)">Last 7 days</option>
                    <option value="30" selected="@(Model.DaysFilter == 30)">Last 30 days</option>
                    <option value="90" selected="@(Model.DaysFilter == 90)">Last 90 days</option>
                </select>
            </div>
            <div class="form-group">
                <label for="resolved" class="mr-2">Status:</label>
                <select name="resolved" id="resolved" class="form-control" onchange="this.form.submit()">
                    <option value="" selected="@(!Model.ResolvedFilter.HasValue)">All</option>
                    <option value="false" selected="@(Model.ResolvedFilter == false)">Unresolved only</option>
                    <option value="true" selected="@(Model.ResolvedFilter == true)">Resolved only</option>
                </select>
        </form>
    </div>
</div>

@if (Model.Statistics.ErrorsByType.Any())
{
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>Errors by Type</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Error Type</th>
                                <th class="text-right">Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var kvp in Model.Statistics.ErrorsByType.OrderByDescending(x => x.Value))
                            {
                                <tr>
                                    <td>@kvp.Key</td>
                                    <td class="text-right"><span class="badge badge-secondary">@kvp.Value</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>Errors by Operation</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Operation</th>
                                <th class="text-right">Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var kvp in Model.Statistics.ErrorsByOperation.OrderByDescending(x => x.Value))
                            {
                                <tr>
                                    <td>@kvp.Key</td>
                                    <td class="text-right"><span class="badge badge-secondary">@kvp.Value</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5>Recent Errors</h5>
            </div>
            <div class="card-body">
                @if (!Model.Errors.Any())
                {
                    <p class="text-muted">No errors found for the selected filters.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Timestamp</th>
                                    <th>Operation</th>
                                    <th>Error Type</th>
                                    <th>Message</th>
                                    <th>Retries</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var error in Model.Errors)
                                {
                                    <tr class="@(error.IsResolved ? "table-success" : (error.IsRetryable ? "table-warning" : "table-danger"))">
                                        <td class="small">@error.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                        <td class="small">@error.Operation</td>
                                        <td class="small">@error.ErrorType</td>
                                        <td class="small" style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@error.ErrorMessage">
                                            @error.ErrorMessage
                                        </td>
                                        <td class="text-center">
                                            @if (error.RetryCount > 0)
                                            {
                                                <span class="badge badge-info">@error.RetryCount</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            @if (error.IsResolved)
                                            {
                                                <span class="badge badge-success">Resolved</span>
                                            }
                                            else if (error.IsRetryable)
                                            {
                                                <span class="badge badge-warning">Retryable</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-danger">Failed</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!error.IsResolved)
                                            {
                                                <form method="post" asp-action="ResolveError" asp-route-storeId="@Model.StoreId" asp-route-errorId="@error.Id" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-success">Resolve</button>
                                                </form>
                                            }
                                            <button type="button" class="btn btn-sm btn-info" data-toggle="collapse" data-target="#error-@error.Id">Details</button>
                                        </td>
                                    </tr>
                                    <tr class="collapse" id="error-@error.Id">
                                        <td colspan="7">
                                            <div class="p-3">
                                                <h6>Full Details</h6>
                                                <dl class="row small">
                                                    @if (!string.IsNullOrEmpty(error.RewardId))
                                                    {
                                                        <dt class="col-sm-2">Reward ID</dt>
                                                        <dd class="col-sm-10">@error.RewardId</dd>
                                                    }
                                                    <dt class="col-sm-2">Error Type</dt>
                                                    <dd class="col-sm-10">@error.ErrorType</dd>
                                                    <dt class="col-sm-2">Message</dt>
                                                    <dd class="col-sm-10">@error.ErrorMessage</dd>
                                                    @if (!string.IsNullOrEmpty(error.StackTrace))
                                                    {
                                                        <dt class="col-sm-2">Stack Trace</dt>
                                                        <dd class="col-sm-10"><pre class="small">@error.StackTrace</pre></dd>
                                                    }
                                                    @if (error.Context?.Any() == true)
                                                    {
                                                        <dt class="col-sm-2">Context</dt>
                                                        <dd class="col-sm-10">
                                                            @if (!string.IsNullOrEmpty(error.Context))
                                                            {
                                                                <pre><code>@error.Context</code></pre>
                                                            }
                                                            else
                                                            {
                                                                <em>None</em>
                                                            }
                                                        </dd>
                                                    }
                                                    @if (error.IsResolved)
                                                    {
                                                        <dt class="col-sm-2">Resolved At</dt>
                                                        <dd class="col-sm-10">@error.ResolvedAt?.ToString("yyyy-MM-dd HH:mm:ss") by @error.ResolvedBy</dd>
                                                    }
                                                </dl>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-12">
        <a asp-action="EditSettings" asp-route-storeId="@Model.StoreId" class="btn btn-secondary">Back to Settings</a>
    </div>
</div>
